---
import config from '../../site.json';

const chatMessages = [
  { text: "We started as neighbors who saw unmet needs and decided to act.", delay: "0s" },
  { text: `Our core values? ${config.values.join(', ')}. Everything we do flows from these.`, delay: "0.1s" },
  { text: "What began with weekend tutoring in a church basement has grown into a full-service nonprofit serving thousands.", delay: "0.2s" },
  { text: "Our mission is simple: create pathways to opportunity through education, mentorship, and direct community action.", delay: "0.3s" },
  { text: "We believe that when one person rises, we all rise.", delay: "0.4s" },
];
---
<section id="about" class="py-24 px-6 lg:px-12">
  <div class="container mx-auto max-w-3xl">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-primary text-primary text-xs tracking-widest uppercase mb-4">Our Story</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Built on the Belief That<br /><span class="text-primary">We Rise Together</span></h2>
    </div>

    <div class="space-y-2 fade-in-up">
      {chatMessages.map((msg, index) => (
        <div class={`chat ${index % 2 === 0 ? 'chat-start' : 'chat-end'}`}>
          <div class="chat-image avatar placeholder">
            <div class="bg-primary text-primary-content w-10 rounded-full">
              <span class="text-xs font-bold">RT</span>
            </div>
          </div>
          <div class="chat-header text-xs text-base-content/50 mb-1">
            {config.business_name}
          </div>
          <div class={`chat-bubble ${index % 2 === 0 ? 'chat-bubble-primary' : 'chat-bubble'}`}>
            {msg.text}
          </div>
        </div>
      ))}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-12 fade-in-up">
      {config.values.map((value) => (
        <div class="bg-primary/5 border border-primary/20 rounded-xl p-4 text-center">
          <p class="font-heading font-semibold text-primary text-sm">{value}</p>
        </div>
      ))}
    </div>
  </div>
</section>
