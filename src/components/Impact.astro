---
import config from '../../site.json';

const stats = [
  { value: config.impact.people_served, label: "People Served", icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" },
  { value: config.impact.programs, label: "Active Programs", icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" },
  { value: config.impact.volunteers, label: "Volunteers", icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" },
  { value: config.impact.years, label: "Years of Service", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
];
---
<section id="impact" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-primary text-primary text-xs tracking-widest uppercase mb-4">Our Impact</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Numbers That Matter</h2>
      <p class="text-base-content/60 mt-4 max-w-xl mx-auto">Every number represents a life changed, a community strengthened, and a step toward equity.</p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
      {stats.map((stat) => (
        <div class="card bg-base-100 shadow-lg border border-base-300/50">
          <div class="card-body items-center text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={stat.icon} />
            </svg>
            <p class="text-3xl md:text-4xl font-heading font-bold text-primary">{stat.value}</p>
            <p class="text-sm text-base-content/60">{stat.label}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
