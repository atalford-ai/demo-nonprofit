---
import config from '../../site.json';
---
<section id="events" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-primary text-primary text-xs tracking-widest uppercase mb-4">Mark Your Calendar</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Upcoming Events</h2>
      <p class="text-base-content/60 mt-4 max-w-xl mx-auto">Join us at our upcoming events and be part of the change happening in our community.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 stagger-children max-w-5xl mx-auto">
      {config.events.map((event) => (
        <div class="card bg-base-100 shadow-lg border border-base-300/50">
          <div class="card-body">
            <div class="flex items-center gap-3 mb-3">
              <div class="bg-primary/10 rounded-xl p-3 text-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-heading font-semibold text-primary text-sm">{event.date}</p>
                <p class="text-xs text-base-content/50">{event.time}</p>
              </div>
            </div>
            <h3 class="card-title font-heading text-lg">{event.title}</h3>
            <div class="flex items-center gap-2 text-base-content/60 text-sm mt-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{event.location}</span>
            </div>
            <div class="card-actions justify-end mt-4">
              <a href="#contact" class="btn btn-outline btn-primary btn-sm">RSVP</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
