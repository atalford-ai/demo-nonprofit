---
import config from '../../site.json';
---
<section id="events" class="py-24 px-6 lg:px-12 bg-base-200/50">
  <div class="container mx-auto max-w-3xl">
    <div class="text-center mb-16 fade-in-up">
      <span class="badge badge-outline border-primary text-primary text-xs tracking-widest uppercase mb-4">Mark Your Calendar</span>
      <h2 class="text-4xl md:text-5xl font-heading font-bold">Upcoming Events</h2>
      <p class="text-base-content/60 mt-4 max-w-xl mx-auto">Join us at our upcoming events and be part of the change happening in our community.</p>
    </div>

    <ul class="timeline timeline-vertical timeline-snap-icon">
      {config.events.map((event, index) => (
        <li>
          {index > 0 && <hr class="bg-primary" />}
          <div class="timeline-middle">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class={`${index % 2 === 0 ? 'timeline-start md:text-end' : 'timeline-end'} mb-10`}>
            <time class="font-mono text-sm text-primary font-semibold">{event.date}</time>
            <div class="text-lg font-heading font-bold mt-1">{event.title}</div>
            <p class="text-base-content/60 text-sm mt-1">{event.time}</p>
            <p class="text-base-content/60 text-sm">{event.location}</p>
            <a href="#contact" class="btn btn-outline btn-primary btn-sm mt-3">RSVP</a>
          </div>
          <hr class="bg-primary" />
        </li>
      ))}
    </ul>
  </div>
</section>
