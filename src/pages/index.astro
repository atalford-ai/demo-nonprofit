---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Impact from '../components/Impact.astro';
import Programs from '../components/Programs.astro';
import Events from '../components/Events.astro';
import Volunteer from '../components/Volunteer.astro';
import Donate from '../components/Donate.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import config from '../../site.json';
---
<BaseLayout title="Home">
  {config.sections.hero && <Hero />}
  {config.sections.impact && <Impact />}
  {config.sections.programs && <Programs />}
  {config.sections.events && <Events />}
  {config.sections.volunteer && <Volunteer />}
  {config.sections.donate && <Donate />}
  {config.sections.about && <About />}
  {config.sections.contact && <Contact />}
</BaseLayout>
